---
/* eslint-disable astro/no-unused-css-selector */
type Props = {
  defaultLanguage?: string;
  supportedLanguages?: string[];
  forceRedirectToDefault?: boolean;
};

const {
  defaultLanguage = 'en',
  supportedLanguages = [],
  forceRedirectToDefault = true
} = Astro.props;

const shouldRender = supportedLanguages && supportedLanguages.length > 1;
---
{shouldRender && (
  <style is:inline>
    html { visibility: hidden; opacity: 0; }
  </style>
  <script
    is:inline
    id='i18n-redirect'
    data-default-language={defaultLanguage}
    data-supported-languages={supportedLanguages.join(',')}
    data-force-redirect={forceRedirectToDefault.toString()}
  >
    const script = document.querySelector('#i18n-redirect');
    const dataDefaultLanguage = script.getAttribute('data-default-language');
    const dataSupportedLanguages = script.getAttribute('data-supported-languages').split(',');
    const forceRedirect = script.getAttribute('data-force-redirect') === 'true';

    const getTargetLanguage = () => {
      const storageLanguage = localStorage.getItem('language');

      if (storageLanguage && dataSupportedLanguages.includes(storageLanguage)) {
        return storageLanguage;
      }

      const browserLang = window.navigator.language.split('-')[0];
      if (dataSupportedLanguages.includes(browserLang)) {
        return browserLang;
      }

      return dataDefaultLanguage;
    };

    const targetLanguage = getTargetLanguage();
    const currentPath = window.location.pathname;
    const pathSegments = currentPath.split('/').filter(Boolean);
    const langInUrl = dataSupportedLanguages.includes(pathSegments[0]) ? pathSegments[0] : null;
    let shouldRedirect = false;
    let finalPath = currentPath;

    if (!langInUrl) {
      if (forceRedirect) {
        shouldRedirect = true;
        finalPath = `/${targetLanguage}${currentPath.startsWith('/') ? currentPath : '/' + currentPath}`;
      }
    } else if (langInUrl !== targetLanguage) {
      localStorage.setItem('language', langInUrl);
    }

    if (shouldRedirect) {
      const cleanPath = finalPath.replace(/\/+/g, '/');
      window.location.replace(cleanPath);
    } else {
      document.documentElement.style.visibility = 'visible';
      document.documentElement.style.opacity = '1';

      if (langInUrl) {
        localStorage.setItem('language', langInUrl);
      }
    }
  </script>
)}